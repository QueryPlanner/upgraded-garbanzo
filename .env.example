# =============================================================================
# Multi-Environment Setup
# =============================================================================
# This project supports running development and production environments
# simultaneously on the same machine.
#
# Environment Files:
#   .env.dev  - Development configuration (port 3001, DEBUG logging)
#   .env.prod - Production configuration (port 3000, INFO logging)
#   .env      - Legacy single-environment (use .env.dev or .env.prod instead)
#
# Quick Start:
#   1. Copy this file to .env.dev and .env.prod
#   2. Fill in your environment-specific credentials
#   3. Run: make dev    (for development)
#   4. Run: make prod   (for production)
#
# See README.md for full multi-environment documentation.
# =============================================================================

# Core Identity
AGENT_NAME=local-agent
# Environment identifier (dev or prod) - used for logging and debugging
ENV=dev

# Durable agent home (Docker default: /home/app/garbanzo-home). This stores
# Garbanzo's repo clones, user-space tools, GitHub/Claude/Gemini config, caches,
# and persistent Playwright browser downloads.
# GARBANZO_HOME=/home/app/garbanzo-home

# Context files (.context): optional override. Default is AGENT_DIR/.context when
# AGENT_DIR is set (Docker: /app/src/.context), else repo-root .context.
# AGENT_CONTEXT_DIR=/path/to/.context

# Skills directory (optional). Dockerfile sets AGENT_SKILLS_DIR=/app/skills in the image.
# AGENT_SKILLS_DIR=/path/to/skills

# Model Configuration
# Use provider/model-name for OpenRouter (e.g., openrouter/google/gemini-2.0-flash-001)
ROOT_AGENT_MODEL=google/gemini-2.0-flash-001


# Anthropic API Base URL and Token (used by Claude Code Tool)
# Required for the coding skill and run_claude_coding_task tool
ANTHROPIC_BASE_URL=http://0.0.0.0:4000
ANTHROPIC_AUTH_TOKEN=your-anthropic-auth-token-here

# API Keys
OPENROUTER_API_KEY=your-openrouter-key-here
# Gemini CLI can also use GOOGLE_API_KEY when you enable it in the container.
GOOGLE_API_KEY=your-google-api-key-here
# Preferred token name for GitHub CLI inside Garbanzo. If unset, Garbanzo falls
# back to GITHUB_TOKEN for git/gh bootstrap.
# GH_TOKEN=github_pat_or_fine_grained_token_here
# OpenAI-compatible API (OpenAI, LiteLLM proxy on :4000, vLLM, etc.).
# Use with e.g. ROOT_AGENT_MODEL=gpt-4o-mini or openai/gpt-4o-mini (not openrouter/).
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=http://localhost:4000
# Docker: localhost is the container — use host.docker.internal (Desktop) or a
# Compose service hostname, not localhost, to reach a proxy on the host.
# Alias for OPENAI_API_BASE (OpenAI SDK convention):
# OPENAI_BASE_URL=http://localhost:4000
GITHUB_TOKEN=your-github-token-here
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Garbanzo git bootstrap defaults. These are written into ~/.gitconfig inside
# the persistent garbanzo home volume on startup.
# GARBANZO_GIT_USER_NAME=QueryPlanner
# GARBANZO_GIT_USER_EMAIL=garbanzo@example.com
# GARBANZO_GIT_DEFAULT_BRANCH=main

# Optional: clone a working repo into Garbanzo's durable workspace on first boot.
# GARBANZO_BOOTSTRAP_REPO=QueryPlanner/upgraded-garbanzo
# GARBANZO_WORKSPACE_ROOT=/home/app/garbanzo-home/workspace
# GARBANZO_BOOTSTRAP_REPO_DIR=/home/app/garbanzo-home/workspace/upgraded-garbanzo

# Optional MCP: Notion MCP via local stdio server for Google ADK.
# Matches the standard MCP config shape:
#   command: npx
#   args: ["-y", "@notionhq/notion-mcp-server"]
#   env: { "NOTION_TOKEN": "..." }
# NOTION_MCP_ENABLED=false
# NOTION_TOKEN=your-notion-integration-token
# NOTION_MCP_COMMAND=npx
# NOTION_MCP_TIMEOUT_SECONDS=30

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Set to 1 for INFO logs: session_ms before run_async, then first ADK stream event
# (first event often includes LLM time — see AGENTS.md Telegram section)
# TELEGRAM_LATENCY_LOG=1

# Database Configuration
# asyncpg requires ssl=require instead of sslmode=require
DATABASE_URL=postgresql://user:pass@host:port/dbname?ssl=require
# false = in-memory ADK sessions only; DATABASE_URL still used for reminders/fitness/etc.
# ADK_USE_DATABASE_SESSION=false

# Reminders, fitness "today", and display times (IANA). Default: Asia/Kolkata (IST)
# AGENT_TIMEZONE=Asia/Kolkata

DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Server Configuration
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# Feature Flags
SERVE_WEB_INTERFACE=true
RELOAD_AGENTS=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false

# ---------------------------------------------------------------------------
# Observability Configuration (Choose One)
# ---------------------------------------------------------------------------

# Option 1: Langfuse (Recommended)
# Setting these automatically configures OTEL_EXPORTER_OTLP_* for Langfuse.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Option 2: Generic OpenTelemetry (Jaeger, Honeycomb, etc.)
# Use this if you are NOT using Langfuse.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ...
